        <!-- Constraint callout -->
        <mxCell id="constraint" value="⚠ Why backends run on the host&#xa;&#xa;MLX requires Apple Metal; Docker Desktop on Mac runs Linux containers in a VM with no Metal/GPU passthrough — and MLX has no Linux wheels. Native Ollama is also much faster than dockerized Ollama. So all three backends run natively, and only the gateway + Caddy are containerized." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0e0;strokeColor=#cc0000;strokeWidth=1;fontSize=11;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1340" y="430" width="220" height="190" as="geometry" />
        </mxCell>

        <!-- Security callout -->
        <mxCell id="sec_callout" value="🔒 Security posture (v1)&#xa;&#xa;• TLS via Caddy 'tls internal' (own CA)&#xa;• Bind to LAN IP only — no public exposure&#xa;• API keys: Argon2id hashed, prefix-indexed&#xa;• Authorization header redacted in logs&#xa;• CORS default-deny (allowlist via env)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f7e0;strokeColor=#2e7d32;strokeWidth=1;fontSize=11;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1340" y="100" width="220" height="160" as="geometry" />
        </mxCell>

        <!-- Request flow callout -->
        <mxCell id="flow_callout" value="📨 Request flow (chat)&#xa;&#xa;1. Client → Caddy (HTTPS, Bearer token)&#xa;2. Caddy → Gateway (internal Docker net)&#xa;3. auth.verify(token) ✓&#xa;4. registry.lookup(model) → backend&#xa;5. adapter.chat_completions(body, stream)&#xa;6. SSE / JSON streamed back verbatim" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57c00;strokeWidth=1;fontSize=11;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;spacingRight=8;" vertex="1" parent="1">
          <mxGeometry x="1340" y="270" width="220" height="150" as="geometry" />
        </mxCell>

